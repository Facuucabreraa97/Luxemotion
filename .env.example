# === FRONTEND (Vite) ===
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_API_URL=http://localhost:3001/api

# === BACKEND (Express) ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AI Services
REPLICATE_API_TOKEN=your-replicate-token
OPENAI_API_KEY=your-openai-key
ELEVENLABS_API_KEY=your-elevenlabs-key
GEMINI_API_KEY=your-gemini-key

# Payments
MP_ACCESS_TOKEN=your-mercadopago-access-token
MP_WEBHOOK_SECRET=your-mercadopago-webhook-secret

# Server Config
CLIENT_URL=http://localhost:5173
PORT=3001
NODE_ENV=development

# CORS (comma-separated origins for production)
ALLOWED_ORIGINS=https://mivideoai.com,https://www.mivideoai.com

# Webhook (public URL for MercadoPago notifications)
WEBHOOK_URL=https://api.mivideoai.com
